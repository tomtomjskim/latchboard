{
  "name": "latchboard",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.12 <23"
  },
  "files": [
    ".nvmrc",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/dogfood-runbook.md",
    "docs/input-format.md",
    "docs/privacy.md",
    "docs/release-checklist.md",
    "docs/superpowers/specs/",
    "docs/troubleshooting.md",
    "index.html",
    "playwright.config.cjs",
    "scripts/",
    "src/",
    "tests/",
    "tsconfig.json",
    "vite.config.ts"
  ],
  "scripts": {
    "demo": "tsx src/server/main.ts --mode demo",
    "dev": "tsx src/server/main.ts",
    "dev:cmux": "tsx src/server/main.ts --mode real --input ~/.cmuxterm/events.jsonl",
    "dev:cmux:aliases": "tsx src/server/main.ts --mode real --input ~/.cmuxterm/events.jsonl --show-repo-aliases",
    "dev:cmux:full": "tsx src/server/main.ts --mode real --input ~/.cmuxterm/events.jsonl --workstream-input ~/.cmuxterm/workstream.jsonl --show-repo-aliases",
    "label:cmux": "tsx src/server/register-workstream-label.ts",
    "release:preflight": "node scripts/release-preflight.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test",
    "typecheck": "tsc --noEmit",
    "build": "vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
